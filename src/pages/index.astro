---
import Base from '../layouts/Base.astro';
---

<Base title="claw.equipment">

  <div id="viewport" style="position:fixed;inset:0;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#000209;">

    <!-- Reference canvas: fixed size, scaled to fit -->
    <div id="canvas" style="width:1200px;height:743px;position:relative;flex-shrink:0;transform-origin:center center;">

      <!-- Figure: fills the canvas -->
      <img src="/actor-figure.png" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:contain;pointer-events:none;" />

      <!-- Ghost UI panels -->
      <div style="position:absolute;top:70px;left:40px;width:180px;height:90px;background:rgba(10,10,18,0.55);border:1px solid rgba(255,255,255,0.06);border-radius:10px;"></div>
      <div style="position:absolute;top:190px;left:40px;width:180px;height:90px;background:rgba(10,10,18,0.55);border:1px solid rgba(255,255,255,0.06);border-radius:10px;"></div>
      <div style="position:absolute;top:70px;right:40px;width:180px;height:90px;background:rgba(10,10,18,0.55);border:1px solid rgba(255,255,255,0.06);border-radius:10px;"></div>
      <div style="position:absolute;top:190px;right:40px;width:180px;height:90px;background:rgba(10,10,18,0.55);border:1px solid rgba(255,255,255,0.06);border-radius:10px;"></div>
      <div style="position:absolute;bottom:60px;right:40px;width:280px;height:180px;background:rgba(10,10,18,0.55);border:1px solid rgba(255,255,255,0.06);border-radius:10px;"></div>
      <div style="position:absolute;bottom:60px;left:40px;width:180px;height:90px;background:rgba(10,10,18,0.55);border:1px solid rgba(255,255,255,0.06);border-radius:10px;"></div>

      <!-- Blur overlay: sits on the canvas too -->
      <div style="position:absolute;inset:0;backdrop-filter:blur(4px) saturate(0.9);-webkit-backdrop-filter:blur(4px) saturate(0.9);background:rgba(0,2,9,0.3);z-index:1;"></div>

      <!-- Form: positioned on the canvas at chest level -->
      <div style="position:absolute;top:235px;left:50%;transform:translateX(-50%);z-index:2;">
        <form class="form" id="sf">
          <input type="email" id="ei" placeholder="your@email.com" required autocomplete="email" class="input" />
          <button type="submit" class="btn">Send</button>
        </form>
      </div>

    </div>
  </div>

</Base>

<style>
  .form {
    display: flex;
    gap: 0;
    width: 380px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(232, 147, 74, 0.25);
    background: rgba(8, 8, 16, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .form:focus-within {
    border-color: rgba(232, 147, 74, 0.5);
    box-shadow: 0 0 30px rgba(232, 147, 74, 0.12);
  }

  .input {
    flex: 1;
    padding: 0.8rem 1rem;
    background: transparent;
    border: none;
    outline: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: 0.02em;
  }

  .input::placeholder {
    color: rgba(255, 255, 255, 0.2);
  }

  .btn {
    padding: 0.8rem 1.4rem;
    background: rgba(232, 147, 74, 0.15);
    border: none;
    border-left: 1px solid rgba(232, 147, 74, 0.2);
    cursor: pointer;
    font-family: 'Cinzel', serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e8934a;
    white-space: nowrap;
    transition: background 0.3s ease;
  }

  .btn:hover {
    background: rgba(232, 147, 74, 0.28);
  }
</style>

<script>
  // Scale canvas to fit viewport (same approach as spark.actor)
  function scaleCanvas() {
    const viewport = document.getElementById('viewport');
    const canvas = document.getElementById('canvas');
    if (!viewport || !canvas) return;
    const vw = viewport.clientWidth;
    const vh = viewport.clientHeight;
    const s = Math.max(vw / 1200, vh / 743);
    canvas.style.transform = `scale(${s})`;
  }

  scaleCanvas();
  window.addEventListener('resize', scaleCanvas);

  // Encryption utilities
  const SALT = import.meta.env.PUBLIC_ENCRYPTION_SALT;
  const SCRIPT_URL = import.meta.env.PUBLIC_APPS_SCRIPT_URL;

  async function deriveKey(salt: string): Promise<CryptoKey> {
    const enc = new TextEncoder();
    const keyMaterial = await crypto.subtle.importKey(
      'raw', enc.encode(salt), 'PBKDF2', false, ['deriveKey']
    );
    return crypto.subtle.deriveKey(
      { name: 'PBKDF2', salt: enc.encode('claw-equipment'), iterations: 100000, hash: 'SHA-256' },
      keyMaterial,
      { name: 'AES-GCM', length: 256 },
      false,
      ['encrypt']
    );
  }

  async function encryptEmail(email: string): Promise<string> {
    const key = await deriveKey(SALT);
    const iv = crypto.getRandomValues(new Uint8Array(12));
    const enc = new TextEncoder();
    const ciphertext = await crypto.subtle.encrypt(
      { name: 'AES-GCM', iv },
      key,
      enc.encode(email)
    );
    // Pack iv + ciphertext as base64
    const packed = new Uint8Array(iv.length + new Uint8Array(ciphertext).length);
    packed.set(iv);
    packed.set(new Uint8Array(ciphertext), iv.length);
    return btoa(String.fromCharCode(...packed));
  }

  // Form handler
  const form = document.getElementById('sf');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('ei') as HTMLInputElement;
    const email = input?.value;
    if (email) {
      try {
        const encrypted = await encryptEmail(email);
        if (!SCRIPT_URL) throw new Error('APPS_SCRIPT_URL not configured');
        await fetch(SCRIPT_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({ ts: Date.now(), data: encrypted }),
        });
        form.outerHTML = '<p style="font-family:Crimson Pro,Georgia,serif;font-size:1rem;color:#f4a85c;">You are on the list.</p>';
      } catch (err) {
        console.error('Submission failed:', err);
      }
    }
  });
</script>
