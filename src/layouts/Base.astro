---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'claw.equipment' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Equip your AI. Coming soon." />
    <meta property="og:title" content="claw.equipment" />
    <meta property="og:description" content="Equip your AI. Coming soon." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://claw.equipment" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
